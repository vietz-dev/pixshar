{
  "name": "@pixshar/api",
  "version": "0.0.23",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:worker": "bun --watch src/worker.ts",
    "build": "bun build src/index.ts src/worker.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "start:worker": "bun dist/worker.js",
    "db:migrate": "bunx prisma migrate dev",
    "db:generate": "bunx prisma generate",
    "db:seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@better-auth/prisma-adapter": "^1.0.0",
    "@effect/platform": "^0.77.0",
    "@effect/platform-bun": "^0.57.0",
    "@hono/zod-validator": "^0.4.0",
    "@pixshar/shared": "workspace:*",
    "@prisma/client": "^6.2.0",
    "archiver": "^8.0.0",
    "better-auth": "^1.2.0",
    "pg": "^8.13.0",
    "pg-boss": "^10.1.3",
    "prom-client": "^15.1.3",
    "effect": "^3.12.0",
    "hono": "^4.6.0",
    "jose": "^6.0.0",
    "prisma": "^6.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bun": "latest",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.0"
  }
}