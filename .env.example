# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# BetterAuth
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# Database (SQLite)
DATABASE_URL=file:./dev.db

# S3 / Garage
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=pixshar
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:3900/pixshar

# Garage Admin (for garage-ui login)
GARAGE_ADMIN_TOKEN=dev-admin-token-do-not-use-in-production

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
WEB_URL=http://localhost:3000

# Download archive debounce (seconds) — time to wait after last upload before building ZIP
DOWNLOAD_DEBOUNCE_SECONDS=600
