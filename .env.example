# Environment
# NODE_ENV=development  # Use 'development' for local dev; defaults to 'production' if unset

# Admin — CHANGE THESE BEFORE DEPLOYING
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# BetterAuth — MUST be a random string of at least 32 characters
BETTER_AUTH_SECRET=change-me-to-a-random-string-that-is-long-enough-for-auth
BETTER_AUTH_URL=http://localhost:3001

# Database (Postgres)
DATABASE_URL=postgresql://pixshar:pixshar@localhost:5432/pixshar?schema=public

# S3 / Garage
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=pixshar
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:3900/pixshar
# Host the browser uses for presigned URLs (direct-to-S3 upload + display).
# Only needed when the API reaches S3 over an internal host the browser cannot
# (e.g. http://garage:3900 in Docker). Defaults to S3_ENDPOINT when unset.
# S3_PUBLIC_ENDPOINT=http://localhost:3900

# Garage Admin (for garage-ui login)
GARAGE_ADMIN_TOKEN=dev-admin-token-do-not-use-in-production

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
WEB_URL=http://localhost:3000

# Download archive debounce (seconds) — quiet period after last upload before building ZIP
DOWNLOAD_DEBOUNCE_SECONDS=60
# Hard ceiling (seconds) — build even if uploads keep arriving, measured from first pending photo
DOWNLOAD_MAX_WAIT_SECONDS=120
# Lease (seconds) before a stalled BUILDING job is reclaimed by another worker
DOWNLOAD_BUILD_LEASE_SECONDS=300

# Resize queue tuning (optional — sane defaults)
# PROCESS_POLL_MS=2000
# PROCESS_LEASE_SECONDS=120
# PROCESS_MAX_ATTEMPTS=4
# PROCESS_MIN_AGE_MS=3000
# PROCESS_BATCH=8
