# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# BetterAuth
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# Database (SQLite)
DATABASE_URL=file:./dev.db

# S3 / Minio
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pixshar
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/pixshar

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
WEB_URL=http://localhost:3000

# Download archive debounce (seconds) — time to wait after last upload before building ZIP
DOWNLOAD_DEBOUNCE_SECONDS=600
